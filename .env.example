# 后端环境变量
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/guardian_db
SPRING_DATASOURCE_USERNAME=guardian
SPRING_DATASOURCE_PASSWORD=guardian123
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 消息队列配置
MQ_HOST=localhost
MQ_PORT=5672
MQ_USERNAME=admin
MQ_PASSWORD=admin123

# 鉴权配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=86400000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# API 文档
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW=60000

# 缓存配置
CACHE_TTL=300
CACHE_MAX_SIZE=10000

# K8s 部署
K8S_NAMESPACE=enterprise-guardian
K8S_REPLICAS=2
